PORT=3001

# LLM provider: gemini (default) or anthropic
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
# Production only — leave blank in local dev (uses firebase-service-account.json instead)
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Google OAuth — create credentials at console.cloud.google.com
# APIs & Services > Credentials > OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Frontend URL (used for OAuth redirect and email links)
FRONTEND_URL=http://localhost:5173
